#!/usr/bin/env python3
"""
gore_creator_bowl_print.py

Generate gores for a 12-inch diameter bowl (open at south pole).
Layout: N gores per sheet on 11x17 inch paper (Tabloid).
Adds a physical scale bar at the bottom of each page: a 1-inch line labeled "1 inch".

Key print correctness requirements:
- PDF page size must remain exactly 11x17 (MediaBox), so NO bbox_inches="tight".
- All layout coordinates are in inches (ax limits are inches).
- Raster imagery is positioned in inch-space via imshow(extent=...).

Usage:
    python gore_creator_bowl_print.py <map_image|auto> [diameter_in] [min_lat] [total_gores] [gores_per_sheet] [--mirror] [--rosette]

Examples:
    python gore_creator_bowl_print.py vector_map.png 12 -60 12 3
    python gore_creator_bowl_print.py auto 12 -60 12 3 --mirror

Outputs:
    <prefix>_bowl_sheet_1.pdf, <prefix>_bowl_sheet_2.pdf, ...
"""

import numpy as np
import matplotlib.pyplot as plt
from matplotlib.path import Path
import matplotlib.patches as patches
from matplotlib.transforms import Affine2D
from PIL import Image, ImageOps
import sys, os
import math


def get_gore_coordinates(diameter_in, num_gores, min_lat_deg, samples=500):
    R = diameter_in / 2.0
    dlam = 2 * np.pi / num_gores

    # Latitude range: South (min_lat) to North (+90)
    min_phi = np.radians(min_lat_deg)
    phis = np.linspace(min_phi, np.pi / 2, samples)

    # Sanson-Flamsteed (Sinusoidal) projection geometry
    # width at phi = R * dlam * cos(phi)
    x_width = R * dlam * np.cos(phis)
    xL = -0.5 * x_width
    xR =  0.5 * x_width
    y  =  R * phis

    return phis, xL, xR, y


def build_path_from_coords(xL, xR, y):
    # Trace up left side, then down right side
    verts = np.vstack([
        np.column_stack((xL, y)),
        np.column_stack((xR[::-1], y[::-1])),
        np.column_stack((xL[0], y[0])),
    ])

    codes = ([Path.MOVETO] +
             [Path.LINETO] * (len(xL) - 1) +
             [Path.LINETO] * (len(xR)) +
             [Path.CLOSEPOLY])

    return Path(verts, codes)


def warp_slice_to_gore(slice_img, diameter_in, num_gores, min_lat_deg):
    W_slice, H_slice = slice_img.size

    # Clamp min_lat into [-90, +90]
    min_lat_deg = max(-90.0, min(90.0, min_lat_deg))

    # Determine pixel range corresponding to [min_lat, 90]
    # Source image assumed: top row = +90, bottom row = -90
    # lat = 90 - (row / H) * 180
    # row = (90 - lat) / 180 * H
    max_row = int((90 - min_lat_deg) / 180.0 * H_slice)
    max_row = max(1, min(H_slice, max_row))

    # Crop slice to needed latitude range (top to max_row)
    active_img = slice_img.crop((0, 0, W_slice, max_row))
    W_act, H_act = active_img.size

    warped = Image.new("RGBA", (W_act, H_act), (0, 0, 0, 0))

    # Rows go from +90 down to min_lat
    phis = np.linspace(np.pi / 2, np.radians(min_lat_deg), H_act)

    for j in range(H_act):
        phi = phis[j]
        scale = abs(np.cos(phi))  # equator=1, pole=0

        if scale < 0.001:
            new_w = 1
        else:
            new_w = max(1, int(round(W_act * scale)))

        row_img = active_img.crop((0, j, W_act, j + 1))
        row_resized = row_img.resize((new_w, 1), Image.BICUBIC)

        offset_x = (W_act - new_w) // 2
        warped.paste(row_resized, (offset_x, j))

    return warped


def generate_synthetic_map():
    print("Generating synthetic map from vector data (geopandas)...")
    try:
        import geopandas as gpd
        from io import BytesIO
    except ImportError:
        print("Error: geopandas not found. Please install: pip install geopandas shapely")
        return None

    world = None

    # Method 1: Some versions ship Natural Earth via geopandas.datasets (deprecated in newer releases)
    try:
        if hasattr(gpd, "datasets"):
            world = gpd.read_file(gpd.datasets.get_path("naturalearth_lowres"))
    except Exception:
        pass

    # Method 2: Fetch geojson from Natural Earth GitHub mirror
    if world is None:
        print("Downloading vector map data...")
        url = "https://raw.githubusercontent.com/nvkelso/natural-earth-vector/master/geojson/ne_110m_admin_0_countries.geojson"
        try:
            world = gpd.read_file(url)
        except Exception as e:
            print(f"Error fetching map data: {e}")
            return None

    dpi = 300
    w_inch = 13.33  # ~4000 px
    h_inch = 6.66

    fig, ax = plt.subplots(figsize=(w_inch, h_inch), dpi=dpi)
    ax.set_xlim(-180, 180)
    ax.set_ylim(-90, 90)
    ax.set_aspect("equal")
    ax.axis("off")

    world.plot(ax=ax, facecolor="none", edgecolor="black", linewidth=0.8)

    buf = BytesIO()
    plt.savefig(buf, format="png", bbox_inches="tight", pad_inches=0, transparent=False)
    plt.close(fig)
    buf.seek(0)

    img = Image.open(buf).convert("RGBA")
    return img


def add_one_inch_scale_bar(ax, page_w, page_h):
    """
    Draw a 1-inch scale bar at the bottom of the page in page-coordinate inches.

    This is intended as a print calibration check: the bar must measure 1.000" on paper.
    """
    # Placement (in inches)
    bar_len = 1.0
    y = 0.55           # distance from bottom edge
    x0 = (page_w - bar_len) / 2.0
    x1 = x0 + bar_len

    tick_h = 0.18
    lw = 1.0

    # Main line
    ax.plot([x0, x1], [y, y], color="black", linewidth=lw, solid_capstyle="butt")

    # End ticks
    ax.plot([x0, x0], [y - tick_h / 2, y + tick_h / 2], color="black", linewidth=lw)
    ax.plot([x1, x1], [y - tick_h / 2, y + tick_h / 2], color="black", linewidth=lw)

    # Label
    ax.text((x0 + x1) / 2.0, y - 0.22, '1 inch', ha="center", va="top", fontsize=9, color="black")


def create_sheets(image_path=None, diameter_in=12.0, total_gores=12, gores_per_sheet=3, min_lat_deg=-60, mirror=False):
    # Load image
    if image_path and image_path.lower() != "auto":
        print(f"Loading {image_path}...")
        try:
            img = Image.open(image_path).convert("RGBA")
        except Exception as e:
            print(f"Error opening image: {e}")
            return
    else:
        img = generate_synthetic_map()
        if img is None:
            return
        img = img.resize((4000, 2000), Image.BICUBIC)
        image_path = "vector_map.png"

    if mirror:
        print("Mirroring image...")
        img = ImageOps.mirror(img)

    W, H = img.size
    num_sheets = math.ceil(total_gores / gores_per_sheet)
    slice_w_px = W / total_gores

    # Geometry
    phis, xL_base, xR_base, y = get_gore_coordinates(diameter_in, total_gores, min_lat_deg)

    # Clip path for the standard gore (no tab)
    clip_path = build_path_from_coords(xL_base, xR_base, y)

    # Tab parameters
    tab_width_max = 0.25  # inches
    tab_offset = np.full_like(phis, tab_width_max)

    # Tabs with relief gaps
    xL_cut = xL_base.copy()
    num_tabs = 6
    gap_ratio = 0.10  # fraction of each segment that is gap

    phi_start = phis[0]
    phi_end = phis[-1]
    phi_range = phi_end - phi_start
    seg_len = phi_range / num_tabs

    for i in range(num_tabs):
        start_seg = phi_start + i * seg_len
        t_start = start_seg + (seg_len * gap_ratio * 0.5)
        t_end = start_seg + seg_len - (seg_len * gap_ratio * 0.5)
        mask = (phis >= t_start) & (phis <= t_end)
        xL_cut[mask] = xL_base[mask] - tab_offset[mask]

    xL_tab = xL_cut
    cut_path_with_tab = build_path_from_coords(xL_tab, xR_base, y)

    x_min = xL_tab.min()
    x_max = xR_base.max()
    y_min = y.min()
    y_max = y.max()

    gore_width_phys = x_max - x_min
    gore_height_phys = y_max - y_min

    print(f"Geometry: {diameter_in}\" sphere, {total_gores} gores.")
    print(f"Gore Dims (w/Tab): {gore_width_phys:.2f}\" x {gore_height_phys:.2f}\"")
    print(f"Latitude Coverage: 90N to {min_lat_deg}S")
    print(f"Layout: {num_sheets} sheets, {gores_per_sheet} gores/sheet")

    # Page settings (inches)
    PAGE_W, PAGE_H = 11.0, 17.0  # portrait tabloid

    # Fit warning (does not affect scale, just layout)
    total_content_width = (gore_width_phys * gores_per_sheet) + 0.5
    if total_content_width > PAGE_W:
        print(f"WARNING: Content width {total_content_width:.2f}\" exceeds page width {PAGE_W}\"")
    if gore_height_phys > PAGE_H:
        print(f"WARNING: Content height {gore_height_phys:.2f}\" exceeds page height {PAGE_H}\"")

    out_prefix = os.path.splitext(os.path.basename(image_path))[0]

    # Generate sheets
    for sheet_idx in range(num_sheets):
        fig = plt.figure(figsize=(PAGE_W, PAGE_H))
        ax = fig.add_subplot(111)

        # Make the axes fill the page; we control margins in our own coordinates.
        fig.subplots_adjust(left=0, right=1, bottom=0, top=1)

        # Page coordinates in inches
        ax.set_xlim(0, PAGE_W)
        ax.set_ylim(0, PAGE_H)
        ax.set_aspect("equal")
        ax.axis("off")

        # Add 1-inch calibration scale bar at bottom
        add_one_inch_scale_bar(ax, PAGE_W, PAGE_H)

        # Horizontal margin to center the gores block
        margin_x = (PAGE_W - (gore_width_phys * gores_per_sheet)) / 2.0

        start_gore = sheet_idx * gores_per_sheet
        gores_on_this_sheet = min(gores_per_sheet, total_gores - start_gore)

        for g_idx in range(gores_on_this_sheet):
            global_gore_idx = start_gore + g_idx
            print(f"Processing Gore {global_gore_idx + 1}/{total_gores}...")

            # Extract slice
            left_px = int(global_gore_idx * slice_w_px)
            right_px = int((global_gore_idx + 1) * slice_w_px)
            if global_gore_idx == total_gores - 1:
                right_px = W
            slice_img = img.crop((left_px, 0, right_px, H))

            # Warp
            warped_gore_img = warp_slice_to_gore(slice_img, diameter_in, total_gores, min_lat_deg)

            # Place on page
            shift_x = margin_x + (g_idx * gore_width_phys) + (gore_width_phys / 2.0)
            shift_y = (PAGE_H / 2.0) - ((y_max + y_min) / 2.0)

            trans = Affine2D().translate(shift_x, shift_y) + ax.transData

            # Image clipped to standard gore (no tab)
            ax.imshow(
                warped_gore_img,
                extent=[xL_base.min(), xR_base.max(), y_min, y_max],
                origin="upper",
                transform=trans,
                clip_path=patches.PathPatch(clip_path, transform=trans),
                clip_on=True,
            )

            # Cut outline (with tab)
            ax.add_patch(
                patches.PathPatch(
                    cut_path_with_tab,
                    facecolor="none",
                    edgecolor="black",
                    linewidth=0.5,
                    transform=trans,
                )
            )

            # Fold line (original west edge)
            path_fold = Path(
                np.column_stack((xL_base, y)),
                [Path.MOVETO] + [Path.LINETO] * (len(xL_base) - 1),
            )
            ax.add_patch(
                patches.PathPatch(
                    path_fold,
                    facecolor="none",
                    edgecolor="gray",
                    linestyle="--",
                    linewidth=0.3,
                    transform=trans,
                )
            )

            # Label
            ax.text(
                shift_x,
                shift_y + (y_min - 0.5),
                f"Gore {global_gore_idx + 1}",
                ha="center",
                va="top",
                fontsize=8,
                transform=ax.transData,
            )

        # Save sheet: DO NOT use bbox_inches='tight' (it breaks page size and scale).
        outfile = f"{out_prefix}_bowl_sheet_{sheet_idx + 1}.pdf"
        fig.savefig(outfile, format="pdf")
        plt.close(fig)
        print(f"Saved {outfile}")

    print("\nPrint check:")
    print("  - In the print dialog, choose 'Actual size' / 100% and disable 'Fit to page'.")
    print("  - Measure the scale bar; it must be exactly 1.000 inch.")


def create_rosette(image_path=None, diameter_in=12.0, total_gores=12, min_lat_deg=-60):
    # This function is left largely unchanged, but note: rosette sizing exceeds 11x17 for typical bowls.
    if image_path and image_path.lower() != "auto":
        print(f"Loading {image_path}...")
        try:
            img = Image.open(image_path).convert("RGBA")
        except Exception as e:
            print(f"Error opening image: {e}")
            return
    else:
        img = generate_synthetic_map()
        if img is None:
            return
        img = img.resize((4000, 2000), Image.BICUBIC)
        image_path = "vector_map.png"

    W, H = img.size
    slice_w_px = W / total_gores

    gores = []
    print("Generating gores for rosette...")
    for i in range(total_gores):
        left_px = int(i * slice_w_px)
        right_px = int((i + 1) * slice_w_px)
        if i == total_gores - 1:
            right_px = W
        slice_img = img.crop((left_px, 0, right_px, H))
        warped = warp_slice_to_gore(slice_img, diameter_in, total_gores, min_lat_deg)
        gores.append(warped)

    R_sphere = diameter_in / 2.0
    angle_span_deg = 90.0 - min_lat_deg
    angle_span_rad = np.radians(angle_span_deg)
    arm_length = R_sphere * angle_span_rad
    rosette_diam_in = 2.0 * arm_length

    print(f"Rosette Diameter: {rosette_diam_in:.2f} inches")
    if rosette_diam_in > 16:
        print("WARNING: Rosette likely too large for a single sheet; this is a preview output.")

    fig = plt.figure(figsize=(rosette_diam_in + 1, rosette_diam_in + 1))
    ax = fig.add_subplot(111)
    ax.set_xlim(-arm_length * 1.05, arm_length * 1.05)
    ax.set_ylim(-arm_length * 1.05, arm_length * 1.05)
    ax.set_aspect("equal")
    ax.axis("off")

    phis, xL_base, xR_base, yy = get_gore_coordinates(diameter_in, total_gores, min_lat_deg)
    y_pole = yy.max()

    base_path = build_path_from_coords(xL_base, xR_base, yy)
    verts = base_path.vertices.copy()
    verts[:, 1] -= y_pole
    base_clip_path = Path(verts, base_path.codes)

    for i in range(total_gores):
        gore_img = gores[i]
        angle_deg = (360.0 / total_gores) * i

        tr = Affine2D().translate(0, -y_pole)
        tr += Affine2D().rotate_deg(-angle_deg)
        tr += ax.transData

        ax.imshow(
            gore_img,
            extent=[xL_base.min(), xR_base.max(), yy.min(), yy.max()],
            origin="upper",
            transform=tr,
            clip_path=patches.PathPatch(base_clip_path, transform=tr),
            clip_on=True,
        )

        ax.add_patch(
            patches.PathPatch(
                base_clip_path,
                facecolor="none",
                edgecolor="black",
                linewidth=0.5,
                transform=tr,
            )
        )

    out_file = f"{os.path.splitext(os.path.basename(image_path))[0]}_rosette_preview.pdf"
    fig.savefig(out_file, format="pdf")
    plt.close(fig)
    print(f"Saved rosette preview: {out_file}")


if __name__ == "__main__":
    img_path = None
    diam = 12.0
    min_lat = -60.0
    total_gores = 12
    gores_per_sheet = 3

    # Filter out flags
    args = [a for a in sys.argv[1:] if not a.startswith("--")]

    if len(args) > 0:
        if args[0].lower() != "auto":
            img_path = args[0]
        else:
            img_path = "auto"

        if len(args) > 1:
            try:
                diam = float(args[1])
            except ValueError:
                pass

        if len(args) > 2:
            try:
                min_lat = float(args[2])
            except ValueError:
                pass

        if len(args) > 3:
            try:
                total_gores = int(args[3])
            except ValueError:
                pass

        if len(args) > 4:
            try:
                gores_per_sheet = int(args[4])
            except ValueError:
                pass

    mirror_mode = "--mirror" in sys.argv
    rosette_mode = "--rosette" in sys.argv

    if img_path is None:
        print("No image provided (or 'auto' selected). Using synthetic vector map.")
        img_path = "auto"

    if rosette_mode:
        create_rosette(img_path, diameter_in=diam, total_gores=total_gores, min_lat_deg=min_lat)
    else:
        create_sheets(img_path, diameter_in=diam, total_gores=total_gores, gores_per_sheet=gores_per_sheet, min_lat_deg=min_lat, mirror=mirror_mode)
